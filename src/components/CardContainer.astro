---
import Card from "./Card.astro";
const { events } = Astro.props;
---

<div class="grid_1-1-1 eventlist">
  {events.map((event) => <Card personData={event} />)}
</div>

<style>
  .grid_1-1-1 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin: 0 auto;
  }
</style>
