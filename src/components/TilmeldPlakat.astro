---
import { Image } from "astro:assets";
const { title, text, plakat, caption, order, phototext } = Astro.props;
---

<section class="grid_plakat">
  <div class="phototext">
    <Image src={plakat} alt="plakat" class="plakat" />
    <p>{phototext}</p>
  </div>
  <div class="content">
    <h3>{title}</h3>
    <h5>{caption}</h5>
    <p>{text}</p>
  </div>
</section>

<style define:vars={{ order }}>
  @media screen and (width>800px) {
    .grid_plakat {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
    .content {
      order: var(--order);
    }
  }
  .plakat {
    max-height: 500px;
  }
  .content {
    place-content: center;
    text-align: left;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.6rem;
    margin: 5rem;
  }
  .phototext {
    place-self: center;
    margin: 0;
    padding: 2rem;
  }
</style>
