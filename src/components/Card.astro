---
const { personData } = Astro.props;
---

<article class="card">
  <div>
    <a href={`/person?id=${personData.id}`}>
      <h5>{personData.name}</h5>
      <p>{personData.short_description}</p>
      <h5>Læs mere →</h5>

      <h4>{personData.date} {personData.end_date}</h4>

      <img src={personData.img} alt="{personData.name}" />
    </a>
  </div>
</article>

<style>
  img {
    display: block;
    width: 350px;
    height: 250px;
    justify-content: center;
    margin: 0 auto;
    padding: 0rem 1rem 1rem 1rem;
  }
  a {
    color: var(--text-color);
    text-decoration: none;
  }
  .card {
    background-color: var(--lys-laks);
    padding: 2rem;
    margin: 1rem;
  }
  .card div {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  h4 {
    text-align: right;
    padding: 1rem 1.1rem 0rem 1rem;
  }
  p {
    padding: 0rem 1rem 0rem 1rem;
  }
  h5 {
    padding: 0rem 1rem 0rem 1rem;
  }
</style>
