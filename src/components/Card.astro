---
const { personData } = Astro.props;
const { slug } = Astro.params;
---

<article class="card">
  <a href={`/events/${personData.slug}`}>
    <h5>{personData.name}</h5>
    <p>{personData.short_description}</p>
    <h5>Læs mere →</h5>
  </a>
  <h4>
    {personData.date}
    {personData.end_date}
  </h4>
  <img src={personData.img} alt={personData.name} />
</article>

<style>
  img {
    display: block;
    width: 300px;
    height: 200px;
    justify-content: center;
    margin: 0 auto;
    padding: 0rem 1rem 1rem 1rem;
  }
  a {
    color: var(--text-color);
    text-decoration: none;
  }

  .card {
    background-color: var(--lys-laks);
    padding: 2rem;
    margin: 1rem;
    display: grid;
    grid-template-rows: subgrid;
    grid-row: span 3;
    gap: 0;
  }

  h4 {
    text-align: right;
    padding: 1rem 1.1rem 0rem 1rem;
  }
  p {
    padding: 0.5rem 1rem 0rem 1rem;
  }
  h5 {
    padding: 0rem 1rem 0rem 1rem;
  }
</style>
