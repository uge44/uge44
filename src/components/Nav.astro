---
const { pathname } = Astro.url;
const logoLink = {
  img: "/img/logo.svg",
  alt: "Logo",
  path: "/",
};
const navLinks = [
  {
    title: "Bliv en del af kampangen ",
    path: "/tilmeld",
  },
  {
    title: "Filmliste ",
    path: "/filmliste",
  },
  {
    title: "Bogliste ",
    path: "/bogliste",
  },
  {
    title: "Events",
    path: "/events",
    cta: true,
  },
];
---

<header>
  <!-- <h1>{Astro.url.pathname}</h1> -->
  <nav>
    <!-- Logo -->
    <a href={logoLink.path}>
      <img src={logoLink.img} alt={logoLink.alt} />
    </a>

    <!-- Menu -->
    <ul>
      {
        navLinks.map((link) => {
          return (
            <li>
              <a href={link.path} class={`${pathname === link.path ? "active" : ""} ${link.cta ? "cta" : ""}`}>
                {link.title}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>

<style>
  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    background-color: var(--background-color);
  }

  nav ul {
    display: flex;
    list-style-type: none;
    margin: 0;
    padding: 0;
  }

  nav ul li {
    margin-left: 1.5rem;
  }

  a {
    color: var(--text-color);
    text-decoration: none;
    font-size: 1.2rem;
  }

  a.active {
    color: var(--orange);
  }

  nav a.cta {
    background-color: var(--laks);
    color: var(--text-color);
    padding: 0.6rem 1.2rem;
    border-radius: 999px;
    font-weight: 600;
  }

  nav a.cta:hover {
    opacity: 0.85;
  }

  nav a.cta.active {
    background-color: var(--orange);
  }
  li {
    margin: 1rem;
  }
</style>
