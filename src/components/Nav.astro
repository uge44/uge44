---
const { pathname } = Astro.url;
const logoLink = {
  img: "/img/logo.svg",
  alt: "Logo",
  path: "/",
};
const navLinks = [
  {
    title: "Bliv en del af kampangen ",
    path: "/tilmeld",
  },
  {
    title: "Filmliste ",
    path: "/filmliste",
  },
  {
    title: "Bogliste ",
    path: "/bogliste",
  },
  {
    title: "Events",
    path: "/events",
    cta: true,
  },
];
---

<header>
  <!-- <h1>{Astro.url.pathname}</h1> -->
  <nav>
    <!-- Logo -->
    <a href={logoLink.path}>
      <img src={logoLink.img} alt={logoLink.alt} />
    </a>

    <!-- Menu -->

    <ul class="nav-main">
      {
        navLinks.map((link) => {
          return (
            <li>
              <a href={link.path} class={`${pathname === link.path ? "active" : ""} ${link.cta ? "cta" : ""}`}>
                {link.title}
              </a>
            </li>
          );
        })
      }
    </ul>
    <button class="burger">
      <span class="line"></span>
      <span class="line"></span>
      <span class="line"></span>
    </button>
  </nav>
</header>

<style>
  /* burger menu */

  .nav-main {
    display: flex;
    list-style: none;
    gap: 2em;
    justify-content: center;
  }

  .nav-main a {
    text-decoration: none;
    color: black;
  }
  .burger {
    width: 30px;
    height: 20px;
    cursor: pointer;
    background: transparent;
    border: 0;
    display: none;
  }
  .burger .line {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--orange);
    margin-bottom: 5px;
    transition: 0.2s linear;
  }
  @media (max-width: 800px) {
    .nav-main {
      display: none;
    }
    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    nav.active .nav-main {
      display: block;
      position: absolute;
      top: 12%;
      right: 0;
      background-color: var(--lys-laks);
      border-radius: 5%;
      width: 200px;
      padding: 1em;
      z-index: 100;
    }
    .burger {
      display: block;
      flex: 0 0 auto;
      margin: 0 20px;
      justify-self: end;
    }
    .burger.active .line:nth-child(1) {
      transform: rotate(45deg) translate(5px, 5px);
      transition: 0.2s linear;
    }
    .burger.active .line:nth-child(2) {
      opacity: 0;
      transition: 0.15s linear;
    }
    .burger.active .line:nth-child(3) {
      transform: rotate(-45deg) translate(5px, -5px);
      transition: 0.2s linear;
    }

    nav.active .nav-main li {
      margin: 40px 20px;
      text-align: right;
    }
    nav.active .nav-main a {
      font-size: 24px;
      color: var(--text-color);
    }
    img {
      padding: 2rem;
    }
  }
  @media (min-width: 800px) {
    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 2rem;
      background-color: var(--bg-color);
    }

    nav ul {
      display: flex;
      list-style-type: none;
      margin: 0;
      padding: 0;
    }

    nav ul li {
      margin-left: 1.5rem;
    }

    a {
      color: var(--text-color);
      text-decoration: none;
      font-size: 1.2rem;
    }

    a.active {
      color: var(--orange);
    }

    nav a.cta {
      background-color: var(--laks);
      color: var(--text-color);
      padding: 0.6rem 1.2rem;
      border-radius: 999px;
      font-weight: 600;
    }

    nav a.cta:hover {
      opacity: 0.85;
    }

    nav a.cta.active {
      background-color: var(--orange);
    }
    li {
      margin: 1rem;
    }
  }
</style>
<script>
  ///@ts-nocheck
  const burger = document.querySelector(".burger");
  const nav = document.querySelector("nav");

  burger.addEventListener("click", () => {
    burger.classList.toggle("active");
    nav.classList.toggle("active");
  });
</script>
